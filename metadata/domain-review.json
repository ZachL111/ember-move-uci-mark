{
  "repo": "ember-move-uci-mark",
  "language": "Elixir",
  "category": "Chess and game engines",
  "goal": "Build an Elixir toolkit that studies uci behavior through log and snapshot fixtures, with replay consistency checks and local-only command execution.",
  "review_model": {
    "terms": [
      "position pressure",
      "move ordering",
      "search width",
      "endgame risk"
    ],
    "lanes": [
      "ship",
      "watch",
      "hold"
    ],
    "score": "signal * 2 + slack + confidence - drag * 3",
    "purpose": "surface the domain-specific cases that need the most careful review"
  },
  "cases": [
    {
      "name": "baseline",
      "focus": "position pressure",
